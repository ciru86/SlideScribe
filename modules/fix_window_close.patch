+def close_cv_window(window_title=None):
+    """
+    Forza la chiusura immediata delle finestre OpenCV (workaround macOS)
+    """
+    try:
+        if window_title:
+            cv2.destroyWindow(window_title)
+        else:
+            cv2.destroyAllWindows()
+    except cv2.error:
+        pass
+
+    for _ in range(8):
+        cv2.waitKey(1)

